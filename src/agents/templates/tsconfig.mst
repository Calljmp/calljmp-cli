{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "@types/node"
    ]
  },
  "include": [
    "**/*.ts",
    ".calljmp/types/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
